# ── 範例檔，請複製為 .env.local 並填入實際值 ──
# 切勿提交 .env.local 或任何實際 secret 進 git

# Notion Integration
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_IMPORT_STATUS_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_SHIPMENT_RECORDS_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_LOGISTICS_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_CHANGE_LOG_DB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Auth passwords — 請設定高強度密碼，勿用範例值
EDIT_PASSWORD=請改成你的高強度密碼
LOGISTICS_PASSWORD=請改成你的高強度密碼

# Auth cookie HMAC secret — 建議獨立設成隨機字串
# 若未設，會 fallback 用 EDIT_PASSWORD 作為 HMAC key
AUTH_SECRET=

# Google Drive (Service Account)
GOOGLE_CLIENT_EMAIL=xxx@xxx.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=xxxxxxxxxxxxxxxxxxxxxx

# Gmail SMTP
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
NOTIFY_EMAILS=alice@example.com,bob@example.com
NOTIFY_EMAILS_AIR=
NOTIFY_EMAILS_SEA=

# Vercel Blob (for file upload - auto-set by Vercel)
BLOB_READ_WRITE_TOKEN=vercel_blob_xxxxxxxxxxxx
